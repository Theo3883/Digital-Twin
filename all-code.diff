                        DashboardView(
                            selectedTab: $selectedTab,
                            viewModel: vm
                        )
                    }
                }
            }
            Tab("ECG", systemImage: "waveform.path.ecg", value: 1) {
                ZStack {
                    MeshGradientBackground()
                    NavigationStack {
                        if let vm = EcgMonitorViewModelFactory.shared {
