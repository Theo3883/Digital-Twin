            Button("Sign Out", role: .destructive) {
                viewModel.signOut()
            }
            Button("Cancel", role: .cancel) {}
        }
        .sheet(isPresented: $container.shouldPresentUserProfileEdit) {
            ProfileEditSheet(
                viewModel: ProfileEditSheetViewModel(repository: repository, user: viewModel.currentUser)
            )
