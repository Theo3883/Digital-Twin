# ── Digital Twin — Web API ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the real values.
# .NET reads nested config keys from env vars using __ as separator (e.g. Jwt__Key → Jwt:Key).

# ── Database ──────────────────────────────────────────────────────────────────
ConnectionStrings__CloudDb=Host=localhost;Port=5432;Database=healthapp;Username=healthapp;Password=healthapp_dev

# ── JWT ───────────────────────────────────────────────────────────────────────
Jwt__Issuer=DigitalTwin.WebAPI
Jwt__Audience=DigitalTwin.DoctorPortal
Jwt__Key=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET_KEY_32_CHARS

# ── Google OAuth (same client ID used by the Doctor Portal) ───────────────────
Google__ClientId=your-google-client-id.apps.googleusercontent.com

# ── Google OAuth (Mobile / iOS) ───────────────────────────────────────────────
# iOS uses a different OAuth client id than web. This must match the `aud` claim
# in the Google id_token received by the iOS app.
Google__MobileClientId=your-ios-client-id.apps.googleusercontent.com


# ── CORS (comma-indexed array; add more as Cors__Origins__1=… etc.) ───────────
Cors__Origins__0=http://localhost:3000

# ── Gemini AI (https://ai.google.dev/) ────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Used as fallback for RxCUI drug lookups when RxNav returns no result.
# If not set, the RxNav-only chain is used (drug lookup may fail for uncommon names).
GEMINI_API_KEY=your-gemini-api-key
