@page "/login"
@inject IAuthApplicationService AuthService
@inject IHealthDataSyncService SyncService
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject DigitalTwin.Services.ILocationSearchService LocationSearch
@implements IAsyncDisposable

<div class="login-root">
    <div class="page-enter" style="width: 100%;">
    @if (!_showRegistrationForm)
    {
        <MudCard Class="glass-card" Elevation="0" Style="max-width: 420px; width: 100%;">
            <MudCardContent>
                <MudStack Spacing="4" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h4" Style="color: var(--text-main); font-weight: 700;">
                        Digital Twin
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--text-sec); text-align: center;">
                        Your personal health monitoring companion
                    </MudText>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="width: 100%;">
                            @_errorMessage
                        </MudAlert>
                    }

                    <div style="width: 100%; height: 1px; background: rgba(255, 255, 255, 0.08); margin: 8px 0;"></div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               StartIcon="@Icons.Custom.Brands.Google"
                               OnClick="SignInWithGoogleAsync"
                               Disabled="_isLoading"
                               Style="text-transform: none; font-weight: 600; height: 48px;">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
                            <span>Signing in...</span>
                        }
                        else
                        {
                            <span>Sign in with Google</span>
                        }
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <MudCard Class="glass-card" Elevation="0" Style="max-width: 480px; width: 100%;">
            <MudCardContent>
                <MudStack Spacing="3">
                    <MudText Typo="Typo.h5" Style="color: var(--text-main); font-weight: 700; text-align: center;">
                        Complete Your Profile
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--text-sec); text-align: center;">
                        Fill in a few details to finish creating your account.
                    </MudText>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Style="width: 100%;">
                            @_errorMessage
                        </MudAlert>
                    }

                    <div style="width: 100%; height: 1px; background: rgba(255, 255, 255, 0.08);"></div>

                    <MudTextField @bind-Value="_googleEmail"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  ReadOnly="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Style="color: var(--text-sec);" />

                    <MudStack Row="true" Spacing="2">
                        <MudTextField @bind-Value="_firstName"
                                      Label="First Name"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="First name is required"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      Placeholder="John" />
                        <MudTextField @bind-Value="_lastName"
                                      Label="Last Name"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Last name is required"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      Placeholder="Doe" />
                    </MudStack>

                    <div style="width: 100%; height: 1px; background: rgba(255, 255, 255, 0.08);"></div>

                    <div class="iti-wrapper">
                        <span class="phone-field-label">Phone Number</span>
                        <input type="tel" id="iti-phone-input" placeholder="Phone number" autocomplete="tel" />
                    </div>

                    <div class="dob-field-wrapper">
                        <span class="dob-icon">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                        </span>
                        <label>Date of Birth</label>
                        <input type="date" @bind="_dateOfBirth" @bind:format="yyyy-MM-dd" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <MudAutocomplete T="DigitalTwin.Services.LocationResult"
                                    Label="City / Location"
                                    Variant="Variant.Outlined"
                                    @bind-Value="_location"
                                    SearchFunc="SearchLocationsAsync"
                                    ToStringFunc="@(r => r?.DisplayName ?? string.Empty)"
                                    MinCharacters="2"
                                    DebounceInterval="350"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                    Placeholder="Start typing a city…"
                                    CoerceText="false"
                                    ResetValueOnEmptyText="true" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               OnClick="CompleteRegistrationAsync"
                               Disabled="_isLoading"
                               Style="text-transform: none; font-weight: 600; height: 48px; margin-top: 8px;">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
                            <span>Creating account...</span>
                        }
                        else
                        {
                            <span>Create Account</span>
                        }
                    </MudButton>

                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               FullWidth="true"
                               Size="Size.Small"
                               OnClick="CancelRegistration"
                               Style="text-transform: none; color: var(--text-sec);">
                        Cancel
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
    </div>
</div>

@code {
    private bool _isLoading;
    private string? _errorMessage;

    private bool _showRegistrationForm;
    private string _googleEmail = string.Empty;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string? _phone;
    private DateTime? _dateOfBirth;
    private DigitalTwin.Services.LocationResult? _location;

    // Track whether iti has been initialised so we only run it once per form show.
    private bool _itiInitialised;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user is not null)
        {
            await SyncAndNavigateHome();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_showRegistrationForm && !_itiInitialised)
        {
            _itiInitialised = true;
            await Js.InvokeVoidAsync(
                "signupFields.initPhoneInput",
                "#iti-phone-input",
                "lib/intl-tel-input/img/flags.webp");
        }
    }

    private async Task SignInWithGoogleAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await AuthService.AuthenticateWithGoogleAsync();

            if (result.IsExistingUser)
            {
                await SyncAndNavigateHome();
            }
            else
            {
                _googleEmail = result.Email;
                _firstName = result.FirstName;
                _lastName = result.LastName;
                _showRegistrationForm = true;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CompleteRegistrationAsync()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(_firstName))
        {
            _errorMessage = "First name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_lastName))
        {
            _errorMessage = "Last name is required.";
            return;
        }

        // Retrieve the E.164 phone number (with country code) from intl-tel-input.
        _phone = await Js.InvokeAsync<string>("signupFields.getPhoneNumber", "#iti-phone-input");
        if (string.IsNullOrWhiteSpace(_phone)) _phone = null;

        _isLoading = true;

        try
        {
            var profile = new ProfileCompletionDto
            {
                FirstName = _firstName.Trim(),
                LastName = _lastName.Trim(),
                Phone = _phone,
                Address = null,
                City = _location?.City,
                Country = _location?.Country,
                DateOfBirth = _dateOfBirth,
            };

            await AuthService.CompleteRegistrationAsync(profile);
            await SyncAndNavigateHome();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async void CancelRegistration()
    {
        _showRegistrationForm = false;
        _itiInitialised = false;
        _errorMessage = null;
        await Js.InvokeVoidAsync("signupFields.destroyPhoneInput", "#iti-phone-input");
    }

    private async Task<IEnumerable<DigitalTwin.Services.LocationResult>> SearchLocationsAsync(
        string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2)
            return Enumerable.Empty<DigitalTwin.Services.LocationResult>();

        return await LocationSearch.SearchAsync(value, ct);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("signupFields.destroyPhoneInput", "#iti-phone-input");
        }
        catch { /* JS runtime may already be disposed on hot-reload */ }
    }

    private async Task SyncAndNavigateHome()
    {
        await SyncService.StartSyncAsync();
        // Fire cloud sync in the background — navigation must not wait for it.
        // If the cloud DB is unreachable the drain timer will retry.
        _ = Task.Run(async () =>
        {
            try   { await SyncService.PushToCloudAsync(); }
            catch { /* cloud unavailable — drain timer retries */ }
        });
        Navigation.NavigateTo("/");
    }
}
