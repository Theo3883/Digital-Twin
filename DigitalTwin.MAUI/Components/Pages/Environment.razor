@page "/environment"
@using System
@using System.Globalization
@implements IDisposable
@inject IEnvironmentApplicationService EnvironmentService
@inject IEnvironmentLocationSource LocationSource
@inject IEnvironmentAnalyticsService AnalyticsService
@inject ICoachingApplicationService CoachingService
@inject IPullRefreshCoordinator PullRefresh

<RequireAuth>
<div class="page-enter" style="padding: 0 16px 32px; display: flex; flex-direction: column; gap: 16px;">

    @* AQI Hero Card / Map *@
    <div style="position: relative;">
    <div class="glass-card" style="position: relative; overflow: hidden; height: 200px; display: flex; flex-direction: column; justify-content: flex-end; padding: 20px; -webkit-mask-image: -webkit-radial-gradient(white, black);">
        @* Gradient + nested image — matches web design structure *@
        <div style="position: absolute; inset: 0; border-radius: inherit; overflow: hidden; background: linear-gradient(to bottom, rgba(30,60,120,0.4), rgba(10,14,26,0.9)); opacity: 0.6;">
            <div style="width: 100%; height: 100%; background: url('https://picsum.photos/seed/bucharest/400/200'); background-size: cover; background-position: center; mix-blend-mode: overlay; filter: blur(2px);"></div>
        </div>
        @if (_loading)
        {
            <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.35); z-index: 2; display: flex; align-items: center; justify-content: center; font-size: 13px; color: rgba(255,255,255,0.9);">Loading…</div>
        }
        <div style="position: relative; z-index: 1;">
            <div style="display: flex; align-items: center; gap: 6px; font-size: 14px; color: rgba(255,255,255,0.8); margin-bottom: 12px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                <span>@_locationDisplay · @DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
            <div style="display: inline-flex; align-items: center; padding: 8px 16px; border-radius: 16px; @_aqiBadgeStyle backdrop-filter: blur(12px);">
                <span style="font-family: var(--font-display); font-weight: 700; font-size: 22px; color: @_aqiTextColor; letter-spacing: -0.5px;">
                    AQI @_aqiValue · @_aqiLabel
                </span>
            </div>
            <p style="font-size: 12px; color: rgba(255,255,255,0.7); margin: 8px 0 0;">@_aqiHeroSubtitle</p>
        </div>
    </div>

    @* 3-dot menu — outside hero card to avoid overflow: hidden clipping *@
    <div style="position: absolute; top: 12px; right: 12px; z-index: 10;">
        <button @onclick="ToggleLocationMenu" style="width: 32px; height: 32px; border-radius: 50%; border: none; background: rgba(0,0,0,0.35); color: rgba(255,255,255,0.8); cursor: pointer; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px);">
            <MudIcon Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Style="color: rgba(255,255,255,0.8);" />
        </button>
        @if (_showLocationMenu)
        {
            <div @onclick="CloseLocationMenu" style="position: fixed; inset: 0; z-index: 99;"></div>
            <div style="position: absolute; top: 36px; right: 0; min-width: 190px; border-radius: 14px; background: #1e2028; border: 1px solid rgba(255,255,255,0.12); box-shadow: 0 8px 32px rgba(0,0,0,0.6); z-index: 100; overflow: hidden;">
                <button @onclick="OpenLocationPopup" style="width: 100%; padding: 13px 16px; background: transparent; border: none; text-align: left; font-size: 14px; color: #ffffff; cursor: pointer; display: flex; align-items: center; gap: 10px;">
                    <MudIcon Icon="@Icons.Material.Filled.EditLocation" Size="Size.Small" Style="color: var(--teal-primary);" />
                    Edit Location
                </button>
            </div>
        }
    </div>
    </div>

    @* Metric Grid (2×3) *@
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        @* PM2.5 *@
        <div class="glass-card" style="padding: 12px; display: flex; flex-direction: column; justify-content: space-between; height: 100px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="font-size: 12px; color: var(--text-sec);">PM2.5</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
            </div>
            <div>
                <div style="font-family: var(--font-rounded); font-size: 20px; color: var(--text-main);">@_pm25.ToString("F0") µg/m³</div>
                <div style="font-size: 11px; color: @_pm25LabelColor; margin-top: 2px;">@_pm25Label</div>
            </div>
        </div>
        @* PM10 *@
        <div class="glass-card" style="padding: 12px; display: flex; flex-direction: column; justify-content: space-between; height: 100px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="font-size: 12px; color: var(--text-sec);">PM10</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
            </div>
            <div>
                <div style="font-family: var(--font-rounded); font-size: 20px; color: var(--text-main);">@_pm10.ToString("F0") µg/m³</div>
                <div style="font-size: 11px; color: @_pm10LabelColor; margin-top: 2px;">@_pm10Label</div>
            </div>
        </div>
        @* Temperature *@
        <div class="glass-card" style="padding: 12px; display: flex; flex-direction: column; justify-content: space-between; height: 100px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="font-size: 12px; color: var(--text-sec);">Temperature</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--amber-warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/></svg>
            </div>
            <div>
                <div style="font-family: var(--font-rounded); font-size: 20px; color: var(--text-main);">@_temperature.ToString("F1")°C</div>
                <div style="font-size: 11px; color: var(--green-positive); margin-top: 2px;">Comfortable</div>
            </div>
        </div>
        @* Humidity *@
        <div class="glass-card" style="padding: 12px; display: flex; flex-direction: column; justify-content: space-between; height: 100px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="font-size: 12px; color: var(--text-sec);">Humidity</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>
            </div>
            <div>
                <div style="font-family: var(--font-rounded); font-size: 20px; color: var(--text-main);">@_humidity.ToString("F0")%</div>
                <div style="font-size: 11px; color: var(--green-positive); margin-top: 2px;">Optimal</div>
            </div>
        </div>
        @* O₃ *@
        <div class="glass-card" style="padding: 12px; display: flex; flex-direction: column; justify-content: space-between; height: 100px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="font-size: 12px; color: var(--text-sec);">O₃ (Ozone)</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-positive)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <div>
                <div style="font-family: var(--font-rounded); font-size: 20px; color: var(--text-main);">@_o3.ToString("F0") µg/m³</div>
                <div style="font-size: 11px; color: var(--green-positive); margin-top: 2px;">Good</div>
            </div>
        </div>
        @* NO₂ *@
        <div class="glass-card" style="padding: 12px; display: flex; flex-direction: column; justify-content: space-between; height: 100px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <span style="font-size: 12px; color: var(--text-sec);">NO₂</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-positive)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <div>
                <div style="font-family: var(--font-rounded); font-size: 20px; color: var(--text-main);">@_no2.ToString("F0") µg/m³</div>
                <div style="font-size: 11px; color: var(--green-positive); margin-top: 2px;">Good</div>
            </div>
        </div>
    </div>

    @* Correlation Chart *@
    <div class="glass-card" style="padding: 20px;">
        <div style="font-family: var(--font-display); font-weight: 600; font-size: 16px; color: var(--text-main); margin-bottom: 16px;">
            Heart Rate vs Air Quality — Last 24h
        </div>
        @if (_analyticsLoading)
        {
            <p style="font-size: 12px; color: var(--text-sec); margin: 0 0 12px;">Loading chart…</p>
        }
        <div style="position: relative; height: 150px; width: 100%; border-bottom: 1px solid rgba(255,255,255,0.1); border-left: 1px solid rgba(255,255,255,0.1); margin-bottom: 8px;">
            <svg viewBox="0 0 100 50" style="width: 100%; height: 100%;" preserveAspectRatio="none">
                @if (_analytics is not null && !string.IsNullOrEmpty(_analytics.HeartRatePath))
                {
                    <path d="@_analytics.HeartRatePath" fill="none" stroke="var(--teal-primary)" stroke-width="1.5" />
                }
                @if (_analytics is not null && !string.IsNullOrEmpty(_analytics.Pm25Path))
                {
                    <path d="@_analytics.Pm25Path" fill="none" stroke="var(--amber-warning)" stroke-width="1.5" stroke-dasharray="3,3" />
                }
            </svg>
            @if (_analytics is not null && _analytics.CorrelationR is double cr && Math.Abs(cr) >= 0.15)
            {
                <div class="glass-chip" style="position: absolute; top: 4px; right: 4px; padding: 3px 8px; font-size: 9px; color: var(--text-sec); border-color: rgba(255,255,255,0.15);">
                    r ≈ @cr.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
                </div>
            }
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 10px; color: var(--text-tert); padding: 0 4px;">
            <span>24h ago</span>
            <span>Now</span>
        </div>
        <div style="font-size: 11px; color: var(--text-sec); margin-top: 12px; line-height: 1.5;">
            @if (_analytics is not null && !string.IsNullOrWhiteSpace(_analytics.Footnote))
            {
                @_analytics.Footnote
            }
            else if (!_analyticsLoading)
            {
                <span>No analytics loaded yet.</span>
            }
        </div>
        <div style="display: flex; gap: 12px; margin-top: 8px; font-size: 10px; color: var(--text-tert);">
            <span><span style="color: var(--teal-primary);">■</span> Heart rate (saved vitals)</span>
            <span><span style="color: var(--amber-warning);">■</span> PM2.5 (saved readings)</span>
        </div>
    </div>

    @* AI Recommendation *@
    <div class="glass-card" style="padding: 16px; border-left: 4px solid var(--teal-primary) !important;">
        <div style="display: flex; align-items: flex-start; gap: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--teal-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 2px;"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
            <div style="flex: 1; min-width: 0;">
                @if (_adviceLoading)
                {
                    <p style="font-size: 13px; color: var(--text-sec); margin: 0;">Generating recommendation…</p>
                }
                else
                {
                    <p style="font-size: 14px; color: rgba(255,255,255,0.9); line-height: 1.6; margin: 0; white-space: pre-wrap;">@_envAdvice</p>
                }
                <div style="display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap;">
                    <span class="glass-chip" style="padding: 2px 10px; font-size: 10px; color: var(--text-tert);">OpenWeatherMap</span>
                </div>
            </div>
        </div>
    </div>

</div>

@* Location popup sheet — draggable *@
@if (_showLocationPopup)
{
    <div @onclick="CloseLocationPopup" style="position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);"></div>
    <div @ref="_sheetRef" @onclick:stopPropagation="true"
         style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 201; background: #1a1d26; border-radius: 24px 24px 0 0; padding: 0 20px calc(24px + env(safe-area-inset-bottom, 16px)); border-top: 1px solid rgba(255,255,255,0.12); box-shadow: 0 -8px 40px rgba(0,0,0,0.6); transform: translateY(@(_sheetTranslateY)px); transition: @(_sheetDragging ? "none" : "transform 0.3s ease"); will-change: transform;">
        @* Drag pill *@
        <div @ontouchstart="OnSheetTouchStart" @ontouchend="OnSheetTouchEnd" @ontouchmove="OnSheetTouchMove" @ontouchmove:preventDefault
             style="width: 100%; padding: 16px 0 20px; display: flex; justify-content: center; align-items: center; cursor: grab; touch-action: none;">
            <div style="width: 40px; height: 4px; background: rgba(255,255,255,0.25); border-radius: 2px;"></div>
        </div>
        <div style="font-family: var(--font-display); font-weight: 600; font-size: 18px; color: var(--text-main); margin-bottom: 20px;">Edit Location</div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
            <button type="button" class="glass-chip" style="cursor: pointer; border: none; font-size: 14px; color: var(--text-main); padding: 12px 16px; display: flex; align-items: center; gap: 10px; justify-content: center;" @onclick="UseMyLocationFromPopupAsync" disabled="@_loading">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" Style="color: var(--teal-primary);" />
                Use my location
            </button>
            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.1);"></div>
                <span style="font-size: 12px; color: var(--text-sec);">or enter a city</span>
                <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.1);"></div>
            </div>
            <input type="text" @bind="_cityInput" @bind:event="oninput" placeholder="e.g. Paris, FR" disabled="@_loading"
                   style="width: 100%; padding: 12px 14px; border-radius: var(--radius-inner); border: 1px solid rgba(255,255,255,0.12); background: rgba(0,0,0,0.25); color: var(--text-main); font-size: 14px; box-sizing: border-box;" />
            <button type="button" class="glass-chip" style="cursor: pointer; border: none; font-size: 14px; color: var(--text-main); padding: 12px 16px;" @onclick="ApplyCityFromPopupAsync" disabled="@(_loading || string.IsNullOrWhiteSpace(_cityInput))">
                Apply city
            </button>
            @if (!string.IsNullOrEmpty(_locationError))
            {
                <p style="margin: 0; font-size: 12px; color: var(--red-critical);">@_locationError</p>
            }
            <p style="margin: 4px 0 0; font-size: 11px; color: var(--text-tert); text-align: center;">
                @(LocationSource.Mode == DigitalTwin.Domain.Enums.EnvironmentLocationMode.Manual ? "Using city name (geocoded)." : "Using device location, or LATITUDE/LONGITUDE from .env if GPS is unavailable.")
            </p>
        </div>
    </div>
}

</RequireAuth>

@code {
    private bool _loading = true;
    private string _locationDisplay = "Loading…";
    private string _cityInput = "";
    private string? _locationError;
    private bool _showLocationMenu;
    private bool _showLocationPopup;

    // Sheet drag state
    private ElementReference _sheetRef;
    private double _sheetTouchStartY;
    private double _sheetTranslateY;
    private bool _sheetDragging;
    private const double SheetDismissThreshold = 120;

    private EnvironmentReadingDto _currentReading = new();
    private EnvironmentAnalyticsDto? _analytics;
    private bool _analyticsLoading;
    private string _envAdvice = "";
    private bool _adviceLoading;

    private double _pm25;
    private double _pm10;
    private double _o3;
    private double _no2;
    private double _temperature;
    private double _humidity;
    private int _aqiValue;
    private AirQualityLevel _aqiLevel = AirQualityLevel.Good;

    private string _aqiLabel => _aqiLevel switch
    {
        AirQualityLevel.Good => "GOOD",
        AirQualityLevel.Moderate => "MODERATE",
        AirQualityLevel.Unhealthy => "UNHEALTHY",
        _ => "GOOD"
    };

    private string _aqiBadgeStyle => _aqiLevel switch
    {
        AirQualityLevel.Good => "background: rgba(48, 209, 88, 0.2); border: 1px solid rgba(48, 209, 88, 0.4);",
        AirQualityLevel.Moderate => "background: rgba(255, 149, 0, 0.2); border: 1px solid rgba(255, 149, 0, 0.4);",
        AirQualityLevel.Unhealthy => "background: rgba(255, 45, 85, 0.2); border: 1px solid rgba(255, 45, 85, 0.4);",
        _ => "background: rgba(48, 209, 88, 0.2); border: 1px solid rgba(48, 209, 88, 0.4);"
    };

    private string _aqiTextColor => _aqiLevel switch
    {
        AirQualityLevel.Good => "var(--green-positive)",
        AirQualityLevel.Moderate => "var(--amber-warning)",
        AirQualityLevel.Unhealthy => "var(--red-critical)",
        _ => "var(--green-positive)"
    };

    private string _pm25Label => _pm25 <= 12 ? "Good" : _pm25 <= 35 ? "Fair" : "Poor";
    private string _pm25LabelColor => _pm25 <= 12 ? "var(--green-positive)" : _pm25 <= 35 ? "var(--amber-warning)" : "var(--red-critical)";
    private string _pm10Label => _pm10 <= 20 ? "Good" : _pm10 <= 50 ? "Fair" : "Poor";
    private string _pm10LabelColor => _pm10 <= 20 ? "var(--green-positive)" : _pm10 <= 50 ? "var(--amber-warning)" : "var(--red-critical)";

    private string _aqiHeroSubtitle => _aqiLevel switch
    {
        AirQualityLevel.Good => "Air quality is good. Outdoor activity is generally fine for most people.",
        AirQualityLevel.Moderate => "Air quality is acceptable. Sensitive groups may want to shorten outdoor exertion.",
        AirQualityLevel.Unhealthy => "Air quality may affect health. Limit outdoor activity and check local guidance.",
        _ => "Air quality information is shown above."
    };

    protected override async Task OnInitializedAsync()
    {
        _cityInput = LocationSource.ManualCityName ?? "";

        var cached = EnvironmentService.GetLastCachedEnvironmentSnapshot();
        if (cached is not null)
            ApplyReading(cached);
        else
            ApplyReading(new EnvironmentReadingDto());

        var cachedAdvice = CoachingService.GetLastEnvironmentAdvice();
        if (cachedAdvice is not null)
            _envAdvice = cachedAdvice.Advice;

        _loading = false;

        PullRefresh.RegisterEnvironment(RefreshEnvironmentAsync);

        await LoadAnalyticsAndAdviceAsync(includeAdvice: cachedAdvice is null);
    }

    private async Task RefreshEnvironmentAsync()
    {
        _locationError = null;
        _loading = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var reading = await EnvironmentService.GetCurrentEnvironmentAsync();
            ApplyReading(reading);
        }
        finally
        {
            _loading = false;
        }

        await LoadAnalyticsAndAdviceAsync();
    }

    private void ToggleLocationMenu() => _showLocationMenu = !_showLocationMenu;
    private void CloseLocationMenu() => _showLocationMenu = false;

    private void OpenLocationPopup()
    {
        _showLocationMenu = false;
        _locationError = null;
        _showLocationPopup = true;
    }

    private void CloseLocationPopup()
    {
        _sheetTranslateY = 0;
        _sheetDragging = false;
        _showLocationPopup = false;
    }

    private void OnSheetTouchStart(TouchEventArgs e)
    {
        if (e.ChangedTouches.Length > 0)
        {
            _sheetTouchStartY = e.ChangedTouches[0].ClientY;
            _sheetDragging = true;
        }
    }

    private void OnSheetTouchMove(TouchEventArgs e)
    {
        if (!_sheetDragging || e.ChangedTouches.Length == 0) return;
        var delta = e.ChangedTouches[0].ClientY - _sheetTouchStartY;
        _sheetTranslateY = Math.Max(0, delta); // only allow dragging down
        StateHasChanged();
    }

    private void OnSheetTouchEnd(TouchEventArgs e)
    {
        if (!_sheetDragging) return;
        _sheetDragging = false;
        if (_sheetTranslateY >= SheetDismissThreshold)
        {
            CloseLocationPopup();
        }
        else
        {
            _sheetTranslateY = 0; // snap back
        }
    }

    private async Task UseMyLocationFromPopupAsync()
    {
        LocationSource.SetMode(DigitalTwin.Domain.Enums.EnvironmentLocationMode.Device);
        try
        {
            _showLocationPopup = false;
            await RefreshEnvironmentAsync();
        }
        catch (Exception ex)
        {
            _locationError = ex.Message;
            _showLocationPopup = true;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyCityFromPopupAsync()
    {
        LocationSource.SetManualCityName(_cityInput);
        LocationSource.SetMode(DigitalTwin.Domain.Enums.EnvironmentLocationMode.Manual);
        try
        {
            _showLocationPopup = false;
            await RefreshEnvironmentAsync();
        }
        catch (Exception ex)
        {
            _locationError = ex.Message;
            _showLocationPopup = true;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAnalyticsAndAdviceAsync(bool includeAdvice = true)
    {
        _analyticsLoading = true;
        _adviceLoading = includeAdvice;
        await InvokeAsync(StateHasChanged);

        try
        {
            _analytics = await AnalyticsService.GetLast24HoursAsync();
        }
        catch (Exception)
        {
            // Keep prior series if refresh fails
        }
        finally
        {
            _analyticsLoading = false;
        }

        if (includeAdvice)
        {
            try
            {
                var advice = await CoachingService.GetEnvironmentAdviceAsync(_currentReading);
                _envAdvice = advice.Advice;
            }
            catch (Exception)
            {
                _envAdvice = "Unable to load recommendation right now.";
            }
            finally
            {
                _adviceLoading = false;
            }
        }
    }

    private void ApplyReading(EnvironmentReadingDto reading)
    {
        _currentReading = reading;
        _locationDisplay = string.IsNullOrWhiteSpace(reading.LocationDisplayName)
            ? "Unknown place"
            : reading.LocationDisplayName;
        _pm25 = reading.PM25;
        _pm10 = reading.PM10;
        _o3 = reading.O3;
        _no2 = reading.NO2;
        _temperature = reading.Temperature;
        _humidity = reading.Humidity;
        _aqiLevel = reading.AirQuality;
        // Display the raw OpenWeather AQI index (1–5) when available
        _aqiValue = reading.AqiIndex > 0 ? reading.AqiIndex : _aqiLevel switch
        {
            AirQualityLevel.Good => 1,
            AirQualityLevel.Moderate => 3,
            AirQualityLevel.Unhealthy => 4,
            _ => 1
        };
    }

    public void Dispose()
    {
        PullRefresh.UnregisterEnvironment();
    }
}
