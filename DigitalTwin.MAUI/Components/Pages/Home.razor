@page "/"
@page "/home"
@implements IDisposable
@inject IVitalsApplicationService VitalsService
@inject IEnvironmentApplicationService EnvironmentService
@inject IPullRefreshCoordinator PullRefresh
@inject IHealthDataSyncService SyncService
@inject IAuthApplicationService AuthService
@inject ISleepSessionRepository SleepRepo
@inject ICoachingApplicationService CoachingService
@inject NavigationManager Navigation

<RequireAuth>
@* Fixed top bar — rendered outside the scrollable flow, no animation *@
<HomeTopBar />

@* Scrollable widget area — sits below the fixed bar *@
<div class="page-enter" style="padding: 72px 20px 32px;">
    <HomeWidgetGrid
        HasProfile="@(_currentUser?.HasPatientProfile == true)"
        HeartRate="@_heartRate"
        SpO2="@_spo2"
        Steps="@_steps"
        EnvReading="@_envReading"
        SleepMinutes="@_sleepMinutes"
        SleepQuality="@_sleepQuality"
        InsightText="@_insightText" />
</div>
</RequireAuth>

@code {
    private IDisposable? _vitalsSubscription;
    private AuthResultDto? _currentUser;

    private double _heartRate;
    private double _spo2;
    private double _steps;
    private double _calories;
    private DateTime _lastUpdated;

    private int _hrTrend;
    private int _spo2Trend;
    private int _stepsTrend;
    private int _caloriesTrend;

    private readonly List<double> _hrHistory = [];
    private readonly List<double> _spo2History = [];
    private readonly List<double> _stepsHistory = [];
    private readonly List<double> _caloriesHistory = [];

    private EnvironmentReadingDto? _envReading;
    private int _sleepMinutes;
    private double _sleepQuality;
    private string? _insightText;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
        // StartSyncAsync is called by MainLayout after the sync gate — do NOT call it here.

        _vitalsSubscription = VitalsService.GetLiveVitals()
            .Subscribe(dto =>
            {
                switch (dto.Type)
                {
                    case VitalSignType.HeartRate:
                        _heartRate = dto.Value;
                        _hrTrend = dto.Trend;
                        AddToHistory(_hrHistory, dto.Value);
                        break;
                    case VitalSignType.SpO2:
                        _spo2 = dto.Value;
                        _spo2Trend = dto.Trend;
                        AddToHistory(_spo2History, dto.Value);
                        break;
                    case VitalSignType.Steps:
                        _steps = dto.Value;
                        _stepsTrend = dto.Trend;
                        AddToHistory(_stepsHistory, dto.Value);
                        break;
                    case VitalSignType.Calories:
                        _calories = dto.Value;
                        _caloriesTrend = dto.Trend;
                        AddToHistory(_caloriesHistory, dto.Value);
                        break;
                }

                _lastUpdated = dto.Timestamp;
                InvokeAsync(StateHasChanged);
            });

        // Use cached environment snapshot immediately — no network call on page load
        _envReading = EnvironmentService.GetLastCachedEnvironmentSnapshot();

        // Load cached insight immediately (synchronous)
        var cachedAdvice = CoachingService.GetLastEnvironmentAdvice();
        if (!string.IsNullOrWhiteSpace(cachedAdvice?.Advice))
            _insightText = cachedAdvice.Advice;

        // Fetch last night's sleep
        try
        {
            var patientId = await AuthService.GetCurrentPatientIdAsync();
            if (patientId.HasValue)
            {
                var today = DateTime.UtcNow.Date;
                var sessions = await SleepRepo.GetByPatientAsync(patientId.Value, from: today.AddDays(-1), to: today.AddDays(1));
                var latest = sessions.OrderByDescending(s => s.EndTime).FirstOrDefault();
                if (latest is not null)
                {
                    _sleepMinutes = latest.DurationMinutes;
                    _sleepQuality = latest.QualityScore;
                }
            }
        }
        catch
        {
            // Leave defaults
        }

        // Refresh env insight in background only when the cached advice is stale.
        // IsEnvironmentAdviceFresh() is synchronous and avoids any Gemini call when hot.
        if (_envReading is not null && !CoachingService.IsEnvironmentAdviceFresh())
        {
            var envSnapshot = _envReading;
            _ = Task.Run(async () =>
            {
                try
                {
                    var advice = await CoachingService.GetEnvironmentAdviceAsync(envSnapshot);
                    if (!string.IsNullOrWhiteSpace(advice.Advice))
                    {
                        _insightText = advice.Advice;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch
                {
                    // Keep cached insight
                }
            });
        }

        PullRefresh.RegisterHome(RefreshHomeEnvironmentAsync);
    }

    private async Task RefreshHomeEnvironmentAsync()
    {
        try
        {
            _envReading = await EnvironmentService.GetCurrentEnvironmentAsync();
        }
        catch
        {
            // Leave previous reading
        }

        // Pull-to-refresh explicitly requests fresh advice — bypass the TTL by
        // calling GetEnvironmentAdviceAsync directly; the service will skip the
        // cache check because we cleared it before calling.
        if (_envReading is not null)
        {
            CoachingService.ClearEnvironmentAdviceCache();
            var envSnapshot = _envReading;
            _ = Task.Run(async () =>
            {
                try
                {
                    var advice = await CoachingService.GetEnvironmentAdviceAsync(envSnapshot);
                    if (!string.IsNullOrWhiteSpace(advice.Advice))
                    {
                        _insightText = advice.Advice;
                        await InvokeAsync(StateHasChanged);
                    }
                }
                catch { }
            });
        }

        await InvokeAsync(StateHasChanged);
    }

    private static void AddToHistory(List<double> history, double value)
    {
        history.Add(value);
        if (history.Count > 20)
            history.RemoveAt(0);
    }

    private static MetricCard.TrendDirection GetTrend(int trend) => trend switch
    {
        > 0 => MetricCard.TrendDirection.Up,
        < 0 => MetricCard.TrendDirection.Down,
        _ => MetricCard.TrendDirection.Stable
    };

    public void Dispose()
    {
        _vitalsSubscription?.Dispose();
        PullRefresh.UnregisterHome();
    }
}
