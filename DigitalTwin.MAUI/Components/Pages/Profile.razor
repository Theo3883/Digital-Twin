@page "/profile"
@inject IAuthApplicationService AuthService
@inject IDoctorAssignmentApplicationService DoctorAssignments
@inject IHealthDataSyncService SyncService
@inject IMedicalHistoryEntryRepository MedicalHistoryRepo
@inject NavigationManager Navigation
@* OcrSheet removed — OCR is now a full-screen page at /ocr/{source} *@

<RequireAuth>
<div class="page-enter" style="padding: 0 16px 32px; display: flex; flex-direction: column; gap: 16px;">

    @if (_currentUser is not null)
    {
        @* Profile Header *@
        <div class="glass-card" style="padding: 20px; display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; overflow: hidden;">
            @* Completion Ring *@
            <div style="position: absolute; top: 16px; right: 16px; width: 48px; height: 48px;">
                <svg viewBox="0 0 36 36" style="width: 100%; height: 100%; transform: rotate(-90deg);">
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="3"/>
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="var(--teal-primary)" stroke-width="3" stroke-dasharray="@(_completionPct), 100"/>
                </svg>
                <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: var(--teal-primary);">@_completionPct%</div>
            </div>

            @* Avatar *@
            <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--teal-primary), #2563eb); display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 700; color: white; margin-bottom: 12px; box-shadow: 0 0 30px rgba(0,212,200,0.3);">
                @if (!string.IsNullOrEmpty(_currentUser.PhotoUrl))
                {
                    <img src="@_currentUser.PhotoUrl" alt="@_currentUser.DisplayName" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                }
                else
                {
                    @_initials
                }
            </div>

            <h2 style="font-family: var(--font-display); font-size: 24px; font-weight: 600; letter-spacing: -0.5px; color: var(--text-main); margin: 0;">@_currentUser.DisplayName</h2>
            <p style="font-size: 14px; color: var(--text-sec); margin-top: 4px;">@(_patient?.BloodType is not null ? $"Blood type: {_patient.BloodType}" : _currentUser.Email)</p>
            <div class="glass-chip" style="padding: 4px 12px; font-size: 12px; color: var(--text-tert); margin-top: 12px;">
                Patient ID: @(_currentUser.UserId.ToString()[..8].ToUpper())
            </div>
        </div>

        @* Profile Form or Card *@
        @if (_showForm)
        {
            <PatientProfileForm IsEditing="@(_patient is not null)"
                                IsSaving="@_isSaving"
                                ErrorMessage="@_formError"
                                InitialBloodType="@_patient?.BloodType"
                                InitialAllergies="@_patient?.Allergies"
                                InitialMedicalHistory="@_patient?.MedicalHistoryNotes"
                                OnSave="SaveProfileAsync"
                                OnCancel="CancelForm" />
        }

        @* Profile Completion *@
        <div class="glass-card" style="padding: 16px;">
            <h3 style="font-size: 14px; font-weight: 600; color: var(--text-main); margin-bottom: 12px;">Profile Completion</h3>
            <div style="display: flex; flex-direction: column; gap: 10px; font-size: 14px;">
                @foreach (var item in _checklistItems)
                {
                    <div style="display: flex; align-items: center; gap: 8px; color: @(item.IsChecked ? "rgba(255,255,255,0.9)" : "var(--text-sec)");">
                        <span style="color: @(item.IsChecked ? "var(--teal-primary)" : "rgba(255,255,255,0.2)");">@(item.IsChecked ? "✓" : "○")</span>
                        @item.Label
                    </div>
                }
            </div>
            @if (!_showForm && _patient is null)
            {
                <button @onclick="ShowCreateForm" style="margin-top: 16px; width: 100%; padding: 10px; border-radius: 12px; border: 1px solid rgba(0,212,200,0.4); background: rgba(0,212,200,0.1); color: var(--teal-primary); font-size: 14px; font-weight: 500; cursor: pointer;">
                    + Complete Medical Profile
                </button>
            }
            else if (!_showForm && _patient is not null)
            {
                <button @onclick="ShowEditForm" style="margin-top: 16px; width: 100%; padding: 10px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: var(--text-sec); font-size: 14px; cursor: pointer;">
                    Edit Medical Profile
                </button>
            }
        </div>

        @* Vital Statistics Grid *@
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <div class="glass-card" style="padding: 12px;">
                <div style="font-size: 12px; color: var(--text-sec); margin-bottom: 4px;">Weight</div>
                <div style="font-family: var(--font-rounded); font-size: 18px; color: var(--text-main);">78 <span style="font-size: 12px; color: var(--text-sec);">kg</span></div>
            </div>
            <div class="glass-card" style="padding: 12px;">
                <div style="font-size: 12px; color: var(--text-sec); margin-bottom: 4px;">Blood Type</div>
                <div style="font-family: var(--font-rounded); font-size: 18px; color: var(--text-main);">@(_patient?.BloodType ?? "—")</div>
            </div>
            <div class="glass-card" style="padding: 12px;">
                <div style="font-size: 12px; color: var(--text-sec); margin-bottom: 4px;">Resting HR</div>
                <div style="font-family: var(--font-rounded); font-size: 18px; color: var(--text-main);">68 <span style="font-size: 12px; color: var(--text-sec);">BPM</span></div>
            </div>
            <div class="glass-card" style="padding: 12px;">
                <div style="font-size: 12px; color: var(--text-sec); margin-bottom: 4px;">Blood Pressure</div>
                <div style="font-family: var(--font-rounded); font-size: 18px; color: var(--text-main);">118/76 <span style="font-size: 10px; color: var(--text-sec);">mmHg</span></div>
            </div>
            <div class="glass-card" style="padding: 12px;">
                <div style="font-size: 12px; color: var(--text-sec); margin-bottom: 4px;">BMI</div>
                <div style="font-family: var(--font-rounded); font-size: 18px; color: var(--text-main);">23.8 <span style="font-size: 10px; color: var(--green-positive);">Normal</span></div>
            </div>
            <div class="glass-card" style="padding: 12px;">
                <div style="font-size: 12px; color: var(--text-sec); margin-bottom: 4px;">Cholesterol</div>
                <div style="font-family: var(--font-rounded); font-size: 18px; color: var(--text-main);">4.2 <span style="font-size: 10px; color: var(--text-sec);">mmol/L</span></div>
            </div>
        </div>

        @* Assigned Doctors *@
        <div class="glass-card" style="padding: 16px;">
            <h3 style="font-size: 14px; font-weight: 600; color: var(--text-main); margin-bottom: 16px;">Assigned Doctors</h3>
            <div style="display: flex; flex-direction: column; gap: 16px;">
                @if (_assignedDoctors.Count == 0)
                {
                    <div style="font-size: 13px; color: var(--text-sec); line-height: 1.6;">
                        No doctor is currently assigned to your profile.
                    </div>
                }
                else
                {
                    @foreach (var doctor in _assignedDoctors)
                    {
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div style="width: 40px; height: 40px; border-radius: 50%;
                                        background: rgba(255,255,255,0.08);
                                        display: flex; align-items: center; justify-content: center;
                                        font-size: 14px; font-weight: 600; color: var(--text-main);
                                        position: relative; flex-shrink: 0; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(doctor.PhotoUrl))
                                {
                                    <img src="@doctor.PhotoUrl" alt="@doctor.FullName"
                                         style="width: 100%; height: 100%; object-fit: cover;" />
                                }
                                else
                                {
                                    @GetInitials(doctor.FullName)
                                }
                            </div>
                            <div style="min-width: 0;">
                                <div style="font-size: 14px; font-weight: 500; color: var(--text-main); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @doctor.FullName
                                </div>
                                <div style="font-size: 12px; color: var(--text-sec); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @doctor.Email
                                </div>
                                <div style="font-size: 10px; color: var(--text-tert); margin-top: 2px;">
                                    Assigned @doctor.AssignedAt.ToLocalTime().ToString("dd MMM yyyy")
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        @* Medical History Timeline *@
        <div class="glass-card" style="padding: 16px;">
            <h3 style="font-size: 14px; font-weight: 600; color: var(--text-main); margin-bottom: 16px;">Medical History</h3>
            @if (_ocrHistory.Count > 0)
            {
                var hasScroll = _ocrHistory.Count > 3;
                <div style="position: relative; border-left: 1px solid rgba(255,255,255,0.1); margin-left: 8px; display: flex; flex-direction: column; gap: 18px; padding-bottom: 8px; @(hasScroll ? "overflow-y:auto; max-height: 270px; padding-right: 6px;" : "")">
                    @foreach (var item in _ocrHistory)
                    {
                        <div style="position: relative; padding-left: 16px;">
                            <div style="position: absolute; left: -6px; top: 6px; width: 12px; height: 12px; border-radius: 50%; background: var(--teal-primary); box-shadow: 0 0 10px rgba(0,212,200,0.5);"></div>
                            <div style="font-size: 12px; color: var(--teal-primary); font-weight: 500; margin-bottom: 4px;">@item.EventDate.ToLocalTime().ToString("dd MMM yyyy")</div>
                            <div style="font-size: 14px; color: rgba(255,255,255,0.95);">@item.Summary</div>
                            <div style="font-size: 11px; color: var(--text-sec); margin-top: 2px;">@item.Title</div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(_patient?.MedicalHistoryNotes))
            {
                <p style="font-size: 14px; color: var(--text-sec); line-height: 1.6;">@_patient.MedicalHistoryNotes</p>
            }
            else
            {
                <div style="position: relative; border-left: 1px solid rgba(255,255,255,0.1); margin-left: 8px; display: flex; flex-direction: column; gap: 24px; padding-bottom: 8px;">
                    <div style="position: relative; padding-left: 16px;">
                        <div style="position: absolute; left: -6px; top: 6px; width: 12px; height: 12px; border-radius: 50%; background: var(--teal-primary); box-shadow: 0 0 10px rgba(0,212,200,0.5);"></div>
                        <div style="font-size: 12px; color: var(--teal-primary); font-weight: 500; margin-bottom: 4px;">Mar 2024</div>
                        <div style="font-size: 14px; color: rgba(255,255,255,0.9);">Paroxysmal SVT episode</div>
                        <div style="font-size: 12px; color: var(--text-sec);">ED visit, cardioverted</div>
                    </div>
                    <div style="position: relative; padding-left: 16px;">
                        <div style="position: absolute; left: -6px; top: 6px; width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4);"></div>
                        <div style="font-size: 12px; color: var(--text-sec); font-weight: 500; margin-bottom: 4px;">Oct 2023</div>
                        <div style="font-size: 14px; color: rgba(255,255,255,0.9);">Started Metoprolol 50mg</div>
                    </div>
                    <div style="position: relative; padding-left: 16px;">
                        <div style="position: absolute; left: -6px; top: 6px; width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4);"></div>
                        <div style="font-size: 12px; color: var(--text-sec); font-weight: 500; margin-bottom: 4px;">Jun 2022</div>
                        <div style="font-size: 14px; color: rgba(255,255,255,0.9);">Echocardiogram — EF 62%</div>
                    </div>
                </div>
            }
        </div>

        @* Medical Documents — OCR *@
        <div class="glass-card" style="padding: 16px;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                <div>
                    <h3 style="font-size: 14px; font-weight: 600; color: var(--text-main); margin: 0;">Medical Documents</h3>
                    <p style="font-size: 12px; color: var(--text-sec); margin: 4px 0 0;">Camera, Photos, or Files — processed locally on device.</p>
                </div>
                <div style="width: 40px; height: 40px; border-radius: 12px; background: rgba(0,212,200,0.14); display: flex; align-items: center; justify-content: center;">
                    <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Primary" Size="Size.Medium" />
                </div>
            </div>

            <div style="display:grid; gap:8px;">
                <button type="button" @onclick="OpenImportDocumentsAsync"
                        style="width: 100%; padding: 12px 14px; border-radius: 12px; border: 1px solid rgba(0,212,200,0.4); background: rgba(0,212,200,0.1); color: var(--teal-primary); font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;">
                    <MudIcon Icon="@Icons.Material.Filled.Article" Style="color: var(--teal-primary);" Size="Size.Small" />
                    <span>Import Documents</span>
                </button>
                <button type="button" @onclick="OpenViewDocumentsAsync"
                        style="width: 100%; padding: 11px 14px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.04); color: var(--text-main); font-size: 13px; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px;">
                    <MudIcon Icon="@Icons.Material.Filled.FolderShared" Style="color: var(--text-main);" Size="Size.Small" />
                    <span>View Documents</span>
                </button>
            </div>
        </div>

        @* Sign Out *@
        <button @onclick="SignOutAsync"
                style="width: 100%; padding: 14px; border-radius: 16px; border: 1px solid rgba(255,59,48,0.3); background: rgba(255,59,48,0.1); color: var(--red-critical); font-size: 15px; font-weight: 600; cursor: pointer;">
            Log out
        </button>
    }

</div>
</RequireAuth>

@code {
    private AuthResultDto? _currentUser;
    private PatientDisplayDto? _patient;
    private List<AssignedDoctorDto> _assignedDoctors = new();
    private List<DigitalTwin.Domain.Models.MedicalHistoryEntry> _ocrHistory = new();
    private bool _showForm;
    private bool _isSaving;
    private string? _formError;
    private List<ProfileCompletionChecklist.ChecklistItem> _checklistItems = new();


    private string _initials => string.IsNullOrEmpty(_currentUser?.DisplayName)
        ? "AM"
        : string.Concat(_currentUser.DisplayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => w[0])).ToUpperInvariant();

    private int _completionPct => _checklistItems.Count == 0 ? 0
        : (int)Math.Round(_checklistItems.Count(i => i.IsChecked) * 100.0 / _checklistItems.Count);

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
        if (_currentUser is not null)
        {
            _patient = await AuthService.GetPatientProfileAsync();
            _assignedDoctors = (await DoctorAssignments.GetAssignedDoctorsAsync(_currentUser.Email)).ToList();
            if (_patient is not null)
                _ocrHistory = (await MedicalHistoryRepo.GetByPatientAsync(_patient.PatientId))
                    .OrderByDescending(x => x.EventDate)
                    .ToList();
        }
        RebuildChecklist();
    }

    private void ShowCreateForm()
    {
        _formError = null;
        _showForm = true;
    }

    private void ShowEditForm()
    {
        _formError = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _formError = null;
    }

    private async Task SaveProfileAsync(PatientProfileDto profile)
    {
        _isSaving = true;
        _formError = null;

        try
        {
            _currentUser = await AuthService.CreatePatientProfileAsync(profile);
            _patient = await AuthService.GetPatientProfileAsync();
            await SyncService.StartVitalsCollectionAsync();
            _showForm = false;
            RebuildChecklist();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task SignOutAsync()
    {
        SyncService.StopSync();
        await AuthService.SignOutAsync();
        _currentUser = null;
        _patient = null;
        Navigation.NavigateTo("/login");
    }

    private void RebuildChecklist()
    {
        _checklistItems = new List<ProfileCompletionChecklist.ChecklistItem>
        {
            new(true, "Personal info"),
            new(_currentUser?.HasPatientProfile == true, "Medical profile"),
            new(!string.IsNullOrEmpty(_patient?.BloodType), "Blood type"),
            new(!string.IsNullOrEmpty(_patient?.Allergies), "Allergies info"),
            new(!string.IsNullOrEmpty(_patient?.MedicalHistoryNotes), "Medical history")
        };
    }

    /// <summary>Opens OCR on the scan hub (camera, Photos, Files) — single entry from Profile.</summary>
    private void OpenImportDocumentsAsync()
    {
        Navigation.NavigateTo("/ocr/camera");
    }

    private void OpenViewDocumentsAsync()
    {
        Navigation.NavigateTo("/ocr/documents");
    }

    private static string GetInitials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return "DR";
        return string.Concat(fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(w => char.ToUpperInvariant(w[0])));
    }
}
