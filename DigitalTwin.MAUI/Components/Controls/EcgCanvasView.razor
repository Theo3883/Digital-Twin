@* EcgCanvasView — Hospital-monitor sweep ECG renderer using HTML Canvas + JSInterop *@
@implements IAsyncDisposable
@inject IJSRuntime JS

<div style="@ContainerStyle">
    @* Grid lines (background) *@
    <svg style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none;" viewBox="0 0 600 160" preserveAspectRatio="none">
        @for (var i = 1; i < 8; i++)
        {
            var x = i * 600 / 8;
            <line x1="@x" y1="0" x2="@x" y2="160" stroke="rgba(0,212,200,0.07)" stroke-width="1" />
        }
        @for (var i = 1; i < 4; i++)
        {
            var y = i * 160 / 4;
            <line x1="0" y1="@y" x2="600" y2="@y" stroke="rgba(0,212,200,0.07)" stroke-width="1" />
        }
    </svg>

    <canvas id="@_canvasId"
            width="600"
            height="160"
            style="position: absolute; inset: 0; width: 100%; height: 100%;" />
</div>

@code {
    [Parameter] public double[] Samples { get; set; } = [];

    private readonly string _canvasId = $"ecg-canvas-{Guid.NewGuid():N}";
    private double[] _lastRendered = [];

    private string ContainerStyle =>
        "position: relative; width: 100%; height: 160px; background: rgba(0, 0, 0, 0.3); " +
        "border-radius: var(--radius-inner); overflow: hidden;";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("EcgCanvas.init", _canvasId);

        if (Samples.Length > 1 && !Samples.SequenceEqual(_lastRendered))
        {
            _lastRendered = Samples;
            var sweepPos = Samples.Length > 0 ? (Samples.Length % 600) : 0;
            await JS.InvokeVoidAsync("EcgCanvas.draw", _canvasId, Samples, sweepPos);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("EcgCanvas.clear", _canvasId); }
        catch { /* Component may already be disposed */ }
    }
}
