# Digital Twin - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# PostgreSQL (Docker)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=healthapp
POSTGRES_PASSWORD=healthapp_dev
POSTGRES_DB=healthapp

# Android emulator: use 10.0.2.2 instead of localhost for POSTGRES_HOST

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_REDIRECT_URI=com.googleusercontent.apps.your-google-oauth-client-id:/oauthredirect

# -----------------------------------------------------------------------------
# OpenWeatherMap (https://openweathermap.org/api)
# -----------------------------------------------------------------------------
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# -----------------------------------------------------------------------------
# Google Air Quality API (https://developers.google.com/maps/documentation/air-quality)
# -----------------------------------------------------------------------------
GOOGLE_AIR_QUALITY_API_KEY=your-google-air-quality-api-key

# -----------------------------------------------------------------------------
# Fallback coordinates (optional)
# Used only when GPS is unavailable and manual city mode is not set — e.g. simulator or
# first launch before a fix is cached. The app uses device location or a typed city name
# for normal operation; you do not need Paris-specific values here.
# -----------------------------------------------------------------------------
LATITUDE=48.8566
LONGITUDE=2.3522

# -----------------------------------------------------------------------------
# Gemini Pro API (https://ai.google.dev/)
# Get your key at: https://aistudio.google.com/app/apikey
# Used for AI chatbot and behavioral coaching features.
# If not set, mock providers are used and a warning is logged on startup.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
