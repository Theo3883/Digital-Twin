@startuml IOS Health App - C4 Application Layer
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title C4 Component Diagram - Application Layer

Container_Boundary(application, "Application Layer") {
    Component(dtos, "DTOs", "C#", "VitalSignDto, EnvironmentReadingDto, MedicationDto, SleepSessionDto, OcrDocumentDto, MedicalHistoryEntryDto, NotificationDto, PatientDto")
    
    Component(mappers, "Mappers", "C#", "VitalSignMapper, EnvironmentReadingMapper, MedicationMapper, OcrDocumentMapper, MedicalHistoryMapper, NotificationMapper, PatientMapper")
    
    Component(validators, "Validators", "FluentValidation", "VitalSignDtoValidator, EnvironmentReadingDtoValidator, MedicationDtoValidator, OcrDocumentDtoValidator, PatientDtoValidator")
    
    Component(app_services, "Application Services", "C#", "VitalsApplicationService, EnvironmentApplicationService, MedicationApplicationService, OcrDocumentApplicationService, MedicalHistoryApplicationService, NotificationApplicationService, PatientApplicationService")
    
    Component(interfaces, "Interfaces", "C#", "IVitalsApplicationService, IEnvironmentApplicationService, IMedicationApplicationService, IOcrApplicationService, IPatientApplicationService")
}

Rel(app_services, dtos, "returns")
Rel(app_services, mappers, "uses")
Rel(app_services, validators, "validates via")
Rel(mappers, dtos, "Domain ↔ DTO")
Rel(validators, dtos, "validates")
Rel(app_services, interfaces, "implements")

note right of app_services
  Application Services orchestrate
  Domain services, manage transactions,
  and implement use cases
end note

SHOW_LEGEND()
@enduml
