@startuml IOS Health App - C4 Domain Layer
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title C4 Component Diagram - Domain Layer

Container_Boundary(domain, "Domain Layer") {
    Component(models, "Models", "C#", "VitalSign, Patient, Medication, EnvironmentReading, SleepSession, OcrDocument, MedicalHistoryEntry, Notification, DoctorPatientAssignment")
    
    Component(services, "Domain Services", "C#", "VitalSignService, EnvironmentAssessmentService, MedicationInteractionService, OcrDocumentService, MedicalHistoryService, MedicationManagementService, HealthAssessmentService")
    
    Component(validators, "Validators", "FluentValidation", "VitalSignValidator, PatientValidator, MedicationValidator, EnvironmentReadingValidator, OcrDocumentValidator")
    
    Component(interfaces, "Interfaces", "C#", "IVitalSignRepository, IHealthDataProvider, IEnvironmentDataProvider, IMedicationInteractionProvider, IOcrProvider, IMedicalAssistantProvider, IAnomalyDetectionProvider")
    
    Component(exceptions, "Exceptions", "C#", "DomainException, InvalidVitalSignException, HealthDataUnavailableException, ValidationException")
    
    Component(events, "Domain Events", "C#", "VitalSignRecordedEvent, MedicationAddedEvent, DocumentScannedEvent, MedicalHistoryExtractedEvent")
}

Rel(services, models, "uses")
Rel(services, interfaces, "depends on")
Rel(validators, models, "validates")
Rel(services, validators, "validates via")
Rel(services, events, "publishes")
Rel(interfaces, models, "returns")

SHOW_LEGEND()
@enduml
