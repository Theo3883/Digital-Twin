@page "/medications"
@using DigitalTwin.Domain.Enums
@implements IDisposable
@inject IMedicationApplicationService MedicationService
@inject IAuthApplicationService AuthService
@inject IPullRefreshCoordinator PullRefresh
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<RequireAuth>
<div class="page-enter" style="padding: 0 16px 180px; display: flex; flex-direction: column; gap: 16px; position: relative; min-height: 100%;">

    @* ── Interaction banner ─────────────────────────────────────────────────── *@
    @{
        var bannerSource = (_interactions.Any() || _hasSearched) ? _interactions : _autoInteractions;
    }
    @if (bannerSource.Any())
    {
        var hi = bannerSource.Count(i => i.Severity == _sevHigh);
        var md = bannerSource.Count(i => i.Severity == _sevMed);
        var lo = bannerSource.Count(i => i.Severity == _sevLow);
        <div class="glass-card" style="padding: 16px; background: rgba(255,149,0,0.1) !important; border-color: rgba(255,149,0,0.3) !important; display: flex; align-items: center; gap: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--amber-warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            <div>
                <h3 style="font-family: var(--font-display); font-weight: 700; color: var(--amber-warning); margin: 0;">⚠ @bannerSource.Count Interaction@(bannerSource.Count == 1 ? "" : "s") Detected</h3>
                <p style="font-size: 12px; color: var(--text-sec); margin-top: 2px;">@hi High · @md Medium · @lo Low Severity</p>
            </div>
        </div>
    }
    else if (_hasSearched)
    {
        <div class="glass-card" style="padding: 16px; background: rgba(52,199,89,0.1) !important; border-color: rgba(52,199,89,0.3) !important; display: flex; align-items: center; gap: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green-positive)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            <div>
                <h3 style="font-family: var(--font-display); font-weight: 700; color: var(--green-positive); margin: 0;">✓ No Interactions Found</h3>
                <p style="font-size: 12px; color: var(--text-sec); margin-top: 2px;">All checked medications are safe to combine</p>
            </div>
        </div>
    }
    else if (!_isLoading && _medications.Count == 0)
    {
        <div class="glass-card" style="padding: 16px; background: rgba(52,199,89,0.1) !important; border-color: rgba(52,199,89,0.3) !important; display: flex; align-items: center; gap: 12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green-positive)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            <div>
                <h3 style="font-family: var(--font-display); font-weight: 700; color: var(--green-positive); margin: 0;">No Medications</h3>
                <p style="font-size: 12px; color: var(--text-sec); margin-top: 2px;">Tap "Add Medication" below to get started</p>
            </div>
        </div>
    }

    @* ── Interaction detail cards ──────────────────────────────────────────── *@
    @{
        var detailSource = _interactions.Any() ? _interactions
                         : (!_hasSearched && _autoInteractions.Any()) ? _autoInteractions
                         : new List<MedicationInteractionDto>();
    }
    @if (detailSource.Any())
    {
        <div style="display: flex; flex-direction: column; gap: 10px;">
            @foreach (var interaction in detailSource)
            {
                var bc = interaction.Severity == _sevHigh ? "var(--red-critical)"
                       : interaction.Severity == _sevMed  ? "var(--amber-warning)" : "#facc15";
                <div class="glass-card" style="padding: 16px; border-left: 4px solid @bc !important;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="@bc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
                            <span style="font-size: 14px; font-weight: 500; color: var(--text-main);">@interaction.DrugARxCui + @interaction.DrugBRxCui</span>
                        </div>
                        <MedicationSafetyBadge Severity="@interaction.Severity" />
                    </div>
                    <p style="font-size: 12px; color: var(--text-sec); line-height: 1.6;">@interaction.Description</p>
                </div>
            }
        </div>
    }

    @* ── Active medications ────────────────────────────────────────────────── *@
    <div style="margin-top: 8px;">
        <h3 style="font-family: var(--font-display); font-weight: 600; font-size: 18px; color: var(--text-main); margin-bottom: 12px;">
            Active Medications · @_activeMeds.Count drug@(_activeMeds.Count == 1 ? "" : "s")
        </h3>

        @if (_isLoading)
        {
            <div style="display: flex; justify-content: center; padding: 32px 0;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            </div>
        }
        else if (_activeMeds.Count == 0 && _endedMeds.Count == 0)
        {
            <div class="glass-card" style="padding: 24px; text-align: center; color: var(--text-sec); font-size: 14px;">
                No medications added yet
            </div>
        }
        else
        {
            <div style="display: flex; flex-direction: column; gap: 8px;">
                @foreach (var med in _activeMeds)
                {
                    <MedicationCard Medication="@med" OnTap="OpenCardMenuAsync" />
                }
            </div>

            @if (_endedMeds.Count > 0)
            {
                <h3 style="font-family: var(--font-display); font-weight: 600; font-size: 16px; color: var(--text-sec); margin: 16px 0 8px 0;">
                    Ended · @_endedMeds.Count medication@(_endedMeds.Count == 1 ? "" : "s")
                </h3>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    @foreach (var med in _endedMeds)
                    {
                        <MedicationCard Medication="@med" OnTap="OpenCardMenuAsync" />
                    }
                </div>
            }
        }
    </div>

    @* ── FAB ──────────────────────────────────────────────────────────────── *@
    <div style="position: fixed; bottom: 96px; left: 0; right: 0; display: flex; justify-content: center; z-index: 40; pointer-events: none;">
        <div style="display: flex; gap: 10px; pointer-events: auto;">
        <button @onclick="OpenInteractionCheckDialogAsync"
                class="glass-pill"
                style="@GetActionButtonStyle(false)">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Check Drug Interactions
        </button>

        <button @onclick="OpenAddMedicationAsync"
                disabled="@_isAddLoading"
                class="glass-pill"
                style="@GetActionButtonStyle(_isAddLoading)">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            @(_isAddLoading ? "Adding…" : "Add Medication")
        </button>
        </div>
    </div>

</div>
</RequireAuth>

@code {
    // Severity aliases to avoid ambiguity with Domain.Enums
    private static readonly DigitalTwin.Application.Enums.InteractionSeverity _sevHigh = DigitalTwin.Application.Enums.InteractionSeverity.High;
    private static readonly DigitalTwin.Application.Enums.InteractionSeverity _sevMed  = DigitalTwin.Application.Enums.InteractionSeverity.Medium;
    private static readonly DigitalTwin.Application.Enums.InteractionSeverity _sevLow  = DigitalTwin.Application.Enums.InteractionSeverity.Low;

    private Guid? _patientId;
    private bool _isLoading;
    private List<MedicationDto> _medications = [];
    private List<MedicationDto> _activeMeds = [];
    private List<MedicationDto> _endedMeds = [];

    private List<MedicationInteractionDto> _interactions = [];
    private List<MedicationInteractionDto> _autoInteractions = [];
    private bool _hasSearched;
    private bool _isAddLoading;

    private static readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        CloseButton = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _patientId = await AuthService.GetCurrentPatientIdAsync();
        if (_patientId.HasValue)
        {
            await LoadMedicationsAsync();
            PullRefresh.RegisterMedications(() => LoadMedicationsAsync(forceRefresh: true));
        }
    }

    // ── Data loading ──────────────────────────────────────────────────────────

    private async Task LoadMedicationsAsync(bool forceRefresh = false)
    {
        if (!_patientId.HasValue) return;
        _isLoading = true;
        try
        {
            var load = await MedicationService.GetMyMedicationsAsync(_patientId.Value, forceRefresh);
            _medications = load.Medications.ToList();
            _activeMeds  = _medications.Where(m => m.Status == MedicationStatus.Active).ToList();
            _endedMeds   = _medications.Where(m => m.Status == MedicationStatus.Discontinued).ToList();
            _autoInteractions = load.AutoInteractions.ToList();
        }
        catch (Exception ex)
        {
            ShowLongError($"Error loading medications: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Card menu ─────────────────────────────────────────────────────────────

    private async Task OpenCardMenuAsync(MedicationDto med)
    {
        var actions = new List<ActionItem>();

        if (med.Status == MedicationStatus.Active)
        {
            actions.Add(new ActionItem(
                "end",
                "End Medication",
                Icons.Material.Filled.CheckCircle,
                "var(--green-positive)"));
        }

        actions.Add(new ActionItem(
            "remove",
            "Remove",
            Icons.Material.Filled.Delete,
            "var(--red-critical)"));

        var parameters = new DialogParameters<ActionMenuDialog>
        {
            { x => x.Title, med.Name },
            { x => x.Actions, actions }
        };

        var dialog = await DialogService.ShowAsync<ActionMenuDialog>(med.Name, parameters, _dialogOptions);
        var result = await dialog.Result;

        if (result is null || result.Canceled || result.Data is not string action) return;

        switch (action)
        {
            case "end":
                await OpenEndReasonDialogAsync(med.Id);
                break;
            case "remove":
                await OpenRemoveReasonDialogAsync(med.Id);
                break;
        }
    }

    private async Task OpenEndReasonDialogAsync(Guid medId)
    {
        var fields = new List<FormFieldDef>
        {
            new("reason", "Reason for ending", "e.g. Treatment completed", FormFieldType.Text, Required: false)
        };

        var parameters = new DialogParameters<FormDialog>
        {
            { x => x.Title, "End Medication" },
            { x => x.SubmitLabel, "End" },
            { x => x.Fields, fields }
        };

        var dialog = await DialogService.ShowAsync<FormDialog>("End Medication", parameters, _dialogOptions);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        var values = result.Data as Dictionary<string, string>;
        var reason = values?.GetValueOrDefault("reason");

        try
        {
            await MedicationService.DiscontinueMedicationAsync(_patientId!.Value, medId, string.IsNullOrWhiteSpace(reason) ? null : reason);
            Snackbar.Add("Medication ended.", Severity.Success);
            await LoadMedicationsAsync();
        }
        catch (Exception ex)
        {
            ShowLongError($"Error: {ex.Message}");
        }
    }

    private async Task OpenRemoveReasonDialogAsync(Guid medId)
    {
        var fields = new List<FormFieldDef>
        {
            new("reason", "Reason for removing", "e.g. Entered by mistake", FormFieldType.Text, Required: true)
        };

        var parameters = new DialogParameters<FormDialog>
        {
            { x => x.Title, "Remove Medication" },
            { x => x.SubmitLabel, "Remove" },
            { x => x.Fields, fields }
        };

        var dialog = await DialogService.ShowAsync<FormDialog>("Remove Medication", parameters, _dialogOptions);
        var result = await dialog.Result;

        if (result is null || result.Canceled) return;

        try
        {
            await MedicationService.DeleteMedicationAsync(_patientId!.Value, medId);
            Snackbar.Add("Medication removed.", Severity.Success);
            await LoadMedicationsAsync();
        }
        catch (Exception ex)
        {
            ShowLongError($"Error: {ex.Message}");
        }
    }

    // ── Add medication ────────────────────────────────────────────────────────

    private async Task OpenAddMedicationAsync()
    {
        if (!_patientId.HasValue)
        {
            Snackbar.Add("No patient profile found. Please complete your profile first.", Severity.Warning);
            return;
        }

        var dialog = await DialogService.ShowAsync<AddMedicationDialog>("Add Medication", new DialogParameters(), _dialogOptions);
        var result = await dialog.Result;

        if (result is null || result.Canceled || result.Data is not AddMedicationDto dto) return;

        _isAddLoading = true;
        try
        {
            await MedicationService.AddMedicationAsync(_patientId.Value, dto, AddedByRole.Patient);
            Snackbar.Add("Medication added.", Severity.Success);
            await LoadMedicationsAsync();
        }
        catch (Exception ex)
        {
            ShowLongError($"Error: {ex.Message}");
        }
        finally
        {
            _isAddLoading = false;
        }
    }

    // ── Drug interaction checker ──────────────────────────────────────────────

    private async Task OpenInteractionCheckDialogAsync()
    {
        var activeRxCuis = _activeMeds
            .Where(m => !string.IsNullOrWhiteSpace(m.RxCui))
            .Select(m => m.RxCui!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        var activeNamesByRxCui = _activeMeds
            .Where(m => !string.IsNullOrWhiteSpace(m.RxCui) && !string.IsNullOrWhiteSpace(m.Name))
            .GroupBy(m => m.RxCui!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First().Name, StringComparer.OrdinalIgnoreCase);

        var parameters = new DialogParameters<CheckDrugInteractionDialog>
        {
            { x => x.ActiveMedicationRxCuis, activeRxCuis },
            { x => x.ActiveMedicationNamesByRxCui, activeNamesByRxCui }
        };

        var dialog = await DialogService.ShowAsync<CheckDrugInteractionDialog>(
            "Check Drug Interactions",
            parameters,
            _dialogOptions);

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            _hasSearched = true;
    }

    private void ShowLongError(string message)
    {
        Snackbar.Add(message, Severity.Error, config =>
        {
            config.ShowCloseIcon = true;
            config.RequireInteraction = false;
            config.VisibleStateDuration = 10000;
        });
    }

    private string GetActionButtonStyle(bool isLoading) =>
        "background: rgba(0,212,200,0.2); border-color: rgba(0,212,200,0.4); color: var(--teal-primary); " +
        "padding: 12px 24px; display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 500; " +
        $"box-shadow: 0 4px 20px rgba(0,212,200,0.2); cursor: {(isLoading ? "not-allowed" : "pointer")}; opacity: {(isLoading ? "0.7" : "1")};";

    public void Dispose() => PullRefresh.UnregisterMedications();
}
