@page "/ocr/{Source}"
@using DigitalTwin.OCR.Components.Pages
@using DigitalTwin.OCR.Components.Shared
@using DigitalTwin.OCR.Models
@using DigitalTwin.OCR.Models.Enums
@using DigitalTwin.OCR.ViewModels
@using DigitalTwin.OCR.Services
@inject NavigationManager Navigation
@inject OcrSessionViewModel ViewModel
@inject SecurityPostureViewModel PostureVm
@inject IAuthApplicationService AuthService

<div class="ocr-fullpage page-enter">

    @* ── Header ─────────────────────────────────────────────────────────────── *@
    <div class="ocr-fullpage-header glass-card">
        <button class="ocr-back-btn" @onclick="GoBack">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                 width="20" height="20">
                <path d="m15 18-6-6 6-6"/>
            </svg>
        </button>
        <span class="ocr-fullpage-title">Medical Documents</span>
        <div style="width: 32px;"></div>
    </div>

    @* ── Page body ───────────────────────────────────────────────────────────── *@
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>
            <div style="padding: 0 16px 40px; display: flex; flex-direction: column; gap: 12px;">

                @if (_sessionRequest is { } req)
                {
                    @switch (_step)
                    {
                        case OcrStep.Scan:
                            <ScanPage Request="req"
                                      OnScanned="OnScanned"
                                      OnImport="GoToImport"
                                      OnDismiss="GoBack" />
                            break;

                        case OcrStep.Import:
                            <ImportPage Request="req"
                                        OnImported="OnScanned"
                                        OnBack="GoToScan"
                                        OnDismiss="GoBack" />
                            break;

                        case OcrStep.Result:
                            <OcrResultPage Request="req"
                                           OnDone="GoBack"
                                           OnBack="GoToScan" />
                            break;
                    }
                }
                else
                {
                    <div class="glass-card" style="padding: 40px; text-align: center;">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }

            </div>
        </ChildContent>
        <ErrorContent Context="ex">
            <div class="glass-card" style="margin: 24px; padding: 24px; text-align: center;">
                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error"
                         Size="Size.Large" Style="margin-bottom: 12px;" />
                <div style="color: var(--mud-palette-error); margin-bottom: 16px;">
                    An OCR error occurred. Your main app is unaffected.
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="GoBack">
                    Go Back
                </MudButton>
            </div>
        </ErrorContent>
    </ErrorBoundary>

</div>

@code {
    [Parameter] public string Source { get; set; } = "camera";

    private OcrSessionRequest? _sessionRequest;
    private OcrStep _step = OcrStep.Scan;
    private ErrorBoundary? _errorBoundary;

    protected override async Task OnParametersSetAsync()
    {
        var source = Source?.Equals("import", StringComparison.OrdinalIgnoreCase) == true
            ? DocumentSourceType.FileImport
            : DocumentSourceType.Camera;

        var user = await AuthService.GetCurrentUserAsync();
        var patientId = user?.UserId ?? Guid.Empty;

        _sessionRequest = new OcrSessionRequest(Source: source, PatientId: patientId);
        _step = source == DocumentSourceType.FileImport ? OcrStep.Import : OcrStep.Scan;
        ViewModel.StateChanged = () => InvokeAsync(StateHasChanged);
    }

    private void OnScanned()
    {
        _step = OcrStep.Result;
        StateHasChanged();
    }

    private void GoToImport() { _step = OcrStep.Import; StateHasChanged(); }
    private void GoToScan()   { _step = OcrStep.Scan;   StateHasChanged(); }

    private void GoBack() => Navigation.NavigateTo("/profile");

    private enum OcrStep { Scan, Import, Result }
}
