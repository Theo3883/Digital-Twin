@inject IAuthApplicationService AuthService
@inject IJSRuntime JS
@implements IDisposable

<div @ref="_barRef" class="home-top-bar">
    <div style="display: flex; align-items: center; gap: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 14px; flex-shrink: 0; overflow: hidden; @_avatarStyle">
            @if (!string.IsNullOrEmpty(_currentUser?.PhotoUrl))
            {
                <img src="@_currentUser.PhotoUrl" alt="@UserName" style="width: 100%; height: 100%; object-fit: cover;" />
            }
            else
            {
                @(UserInitials)
            }
        </div>
        <div style="display: flex; flex-direction: column;">
            <span style="font-size: 18px; font-weight: 600; line-height: 1.2; letter-spacing: -0.3px; color: var(--text-main);">@UserName</span>
            <span style="font-size: 12px; color: var(--text-sec); font-weight: 500;">@Greeting</span>
        </div>
    </div>
    <button class="glass-pill" style="width: 40px; height: 40px; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; position: relative; background: var(--glass-bg);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--text-main)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        <div style="position: absolute; top: 8px; right: 10px; width: 8px; height: 8px; background: var(--red-critical); border-radius: 50%;"></div>
    </button>
</div>

@code {
    private AuthResultDto? _currentUser;
    private ElementReference _barRef;
    private DotNetObjectReference<HomeTopBar>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("HomeTopBar.init", _barRef);
        }
    }

    private string UserName => _currentUser?.DisplayName ?? "User";

    private string UserInitials => string.IsNullOrEmpty(_currentUser?.DisplayName)
        ? "U"
        : string.Concat(_currentUser.DisplayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => w[0])).ToUpperInvariant();

    private static string Greeting
    {
        get
        {
            var h = DateTime.Now.Hour;
            if (h < 12) return "Good Morning";
            if (h < 18) return "Good Afternoon";
            return "Good Evening";
        }
    }

    private string _avatarStyle => !string.IsNullOrEmpty(_currentUser?.PhotoUrl)
        ? "background: transparent; border: none;"
        : "background: linear-gradient(135deg, #60a5fa, #a855f7); border: 1px solid rgba(255,255,255,0.2);";

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
