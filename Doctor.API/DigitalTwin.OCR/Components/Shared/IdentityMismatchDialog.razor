@using DigitalTwin.OCR.Models

<MudDialog>
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 10px;">
            <MudIcon Icon="@Icons.Material.Filled.WarningAmber"
                     Style="color: var(--text-critical, #ff453a);" Size="Size.Medium" />
            <MudText Typo="Typo.h6"
                     Style="font-family: var(--font-display); font-weight: 700; color: var(--text-main, #f5f5f7);">
                Document Identity Mismatch
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <div class="glass-card" style="padding: 20px; margin-top: 8px;">
            <div style="font-size: 0.92rem; color: var(--text-sec, #a1a1a6); line-height: 1.5; margin-bottom: 16px;">
                @Result.ToUserMessage()
            </div>

            @if (Result.FailureReason is IdentityValidationFailureReason.NameMismatch)
            {
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <div class="identity-row">
                        <span class="identity-label">Document name</span>
                        <span class="identity-value" style="color: var(--text-critical, #ff453a);">@Result.ExtractedName</span>
                    </div>
                    <div class="identity-row">
                        <span class="identity-label">Your profile</span>
                        <span class="identity-value">@Result.ExpectedName</span>
                    </div>
                </div>
            }
            else if (Result.FailureReason is IdentityValidationFailureReason.CnpMismatch)
            {
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <div class="identity-row">
                        <span class="identity-label">Document CNP</span>
                        <span class="identity-value" style="color: var(--text-critical, #ff453a);">@MaskCnp(Result.ExtractedCnp)</span>
                    </div>
                    <div class="identity-row">
                        <span class="identity-label">Your CNP</span>
                        <span class="identity-value">@MaskCnp(Result.ExpectedCnp)</span>
                    </div>
                </div>
            }
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   OnClick="Dismiss"
                   Style="border-radius: 20px; padding: 6px 24px; font-weight: 600;">
            Dismiss
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public IdentityValidationResult Result { get; set; } = null!;

    private void Dismiss() => MudDialog.Cancel();

    private static string MaskCnp(string? cnp)
    {
        if (string.IsNullOrWhiteSpace(cnp) || cnp.Length < 6)
            return cnp ?? "—";
        // Show first 3 and last 3 digits, mask the middle
        return $"{cnp[..3]}*******{cnp[^3..]}";
    }
}
