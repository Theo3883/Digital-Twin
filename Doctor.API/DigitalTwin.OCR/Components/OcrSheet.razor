@implements IDisposable
@inject IOcrSheetService SheetServiceInterface
@inject OcrSheetService SheetService

@* Single root div anchored to the viewport via position:fixed / inset:0.
   The backdrop and panel are children — this avoids the BlazorWebView scroll-container
   eating fixed positioning. *@
<div class="ocr-sheet-root @(_visible ? "visible" : "")">

    <div class="ocr-sheet-backdrop" @onclick="OnBackdropClick"></div>

    <div class="ocr-sheet-panel">
        <div class="ocr-sheet-handle"></div>

        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @if (_visible && SheetService.CurrentRequest is { } req)
                {
                    <div class="ocr-sheet-content">
                        @switch (_currentPage)
                        {
                            case OcrSheetPage.Scan:
                                <ScanPage Request="req"
                                          OnScanned="OnScanned"
                                          OnImport="() => _currentPage = OcrSheetPage.Import"
                                          OnDismiss="Dismiss" />
                                break;
                            case OcrSheetPage.Import:
                                <ImportPage Request="req"
                                            OnImported="OnScanned"
                                            OnBack="() => _currentPage = OcrSheetPage.Scan"
                                            OnDismiss="Dismiss" />
                                break;
                            case OcrSheetPage.Result:
                                <OcrResultPage Request="req"
                                               OnDone="Dismiss"
                                               OnBack="() => _currentPage = OcrSheetPage.Scan" />
                                break;
                        }
                    </div>
                }
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="glass-card" style="padding: 24px; margin: 24px; text-align: center;">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline"
                             Color="Color.Error" Size="Size.Large" Style="margin-bottom:12px;" />
                    <div style="color: var(--mud-palette-error);">
                        An OCR error occurred. Your main app is unaffected.
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               Style="margin-top:16px;" OnClick="Dismiss">
                        Close
                    </MudButton>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </div>

</div>

@code {
    private bool _visible;
    private IDisposable? _subscription;
    private ErrorBoundary? _errorBoundary;
    private OcrSheetPage _currentPage = OcrSheetPage.Scan;

    protected override void OnInitialized()
    {
        _subscription = SheetService.IsVisible.Subscribe(visible =>
        {
            _visible = visible;
            if (visible)
            {
                _currentPage = OcrSheetPage.Scan;
                _errorBoundary?.Recover();
            }
            InvokeAsync(StateHasChanged);
        });
    }

    private void OnBackdropClick()
    {
        // Tapping the backdrop dismisses with Cancelled
        Dismiss();
    }

    private void OnScanned()
    {
        _currentPage = OcrSheetPage.Result;
        StateHasChanged();
    }

    private void Dismiss()
    {
        SheetService.Dismiss();
    }

    public void Dispose() => _subscription?.Dispose();

    private enum OcrSheetPage { Scan, Import, Result }
}
