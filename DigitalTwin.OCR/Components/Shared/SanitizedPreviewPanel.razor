<div class="glass-card" style="padding: 16px; margin-bottom: 12px;">
    <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
        <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
        Sanitized OCR Preview
    </div>
    <div style="font-size: 0.78rem; color: rgba(255,255,255,0.45); margin-bottom: 10px;">
        Personal data has been redacted. Original content is securely encrypted on your device.
    </div>

    @if (string.IsNullOrWhiteSpace(SanitizedText))
    {
        <div style="color: var(--text-secondary); font-size: 0.82rem; text-align: center; padding: 16px;">
            No text could be extracted.
        </div>
    }
    else
    {
        <div style="font-family: 'SF Mono', 'Cascadia Code', monospace; font-size: 0.78rem; color: var(--text-main);
                    white-space: pre-wrap; word-break: break-word; line-height: 1.5;
                    max-height: 320px; overflow-y: auto; padding: 8px; border-radius: 10px;
                    background: rgba(255,255,255,0.04);">
            @SanitizedText
        </div>
    }
</div>

@code {
    [Parameter] public string? SanitizedText { get; set; }
}
